{
  "name": "@stoachain/ouronet-codex",
  "version": "0.5.0",
  "description": "Modular React Codex for the Ouronet ecosystem. Drop-in <CodexProvider> + hooks + headless components giving any React consumer (OuronetUI, AncientHoldings hub, future apps) full 1:1 Codex functionality — onboarding flows, CodexPrime account, account/key management, address book, encrypted backup/restore, Google Drive sync, per-account on-chain operations (rotate guard/payment/sovereign/governor). Peer-deps the @stoachain v4.2 atomic triplet (kadena-stoic-legacy + stoa-core + ouronet-core) for chain logic; owns its own internal state (Zustand) so consumers don't need Redux.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./codex-identity": {
      "types": "./dist/codex-identity/index.d.ts",
      "import": "./dist/codex-identity/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ui.css": "./dist/ui.css",
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./google-drive": {
      "types": "./dist/google-drive/index.d.ts",
      "import": "./dist/google-drive/index.js"
    },
    "./zbom": {
      "types": "./dist/zbom/index.d.ts",
      "import": "./dist/zbom/index.js"
    }
  },
  "files": [
    "dist",
    "dist/ui.css",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy:ui-css && npm run copy:pact-parser",
    "copy:ui-css": "node -e \"require('fs').copyFileSync('src/ui/tokens.css','dist/ui.css')\"",
    "copy:pact-parser": "node -e \"const fs=require('fs');fs.copyFileSync('src/zbom/lang-pact/pact.parser.js','dist/zbom/lang-pact/pact.parser.js');fs.copyFileSync('src/zbom/lang-pact/pact.parser.d.ts','dist/zbom/lang-pact/pact.parser.d.ts')\"",
    "gen:pact-parser": "lezer-generator src/zbom/lang-pact/pact.grammar -o src/zbom/lang-pact/pact.parser.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "_peerDependenciesComment": "@stoachain/dalos-crypto range is '>=4.0.0' (NOT >=4.3.0) on purpose: dalos-crypto tracks an independent v4.x line (current 4.0.3) separate from the kadena-stoic-legacy/stoa-core/ouronet-core 4.3 co-release triplet. A '>=4.3.0' pin would be unsatisfiable. Used directly by src/codex-identity/derivation.ts (Apollo curve key-gen). @noble/curves is pinned to 1.9.7 to match @stoachain/stoa-core's exact peer pin (single shared instance); used directly by src/state/store.ts for fresh ED25519 CodexGuard / Duo Pure Prime keypair generation.",
  "peerDependencies": {
    "@noble/curves": "1.9.7",
    "@stoachain/dalos-crypto": ">=4.0.0",
    "@stoachain/kadena-stoic-legacy": ">=4.3.0",
    "@stoachain/ouronet-core": ">=4.3.0",
    "@stoachain/stoa-core": ">=4.3.0",
    "lucide-react": ">=0.400.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@uiw/react-codemirror": "^4.25.4",
    "clsx": "^2.1.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.483.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StoaChain/stoa-js.git",
    "directory": "packages/ouronet-codex"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "UNLICENSED"
}
