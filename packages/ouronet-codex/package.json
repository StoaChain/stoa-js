{
  "name": "@stoachain/ouronet-codex",
  "version": "0.2.0",
  "description": "Modular React Codex for the Ouronet ecosystem. Drop-in <CodexProvider> + hooks + headless components giving any React consumer (OuronetUI, AncientHoldings hub, future apps) full 1:1 Codex functionality — onboarding flows, CodexPrime account, account/key management, address book, encrypted backup/restore, Google Drive sync, per-account on-chain operations (rotate guard/payment/sovereign/governor). Peer-deps the @stoachain v4.2 atomic triplet (kadena-stoic-legacy + stoa-core + ouronet-core) for chain logic; owns its own internal state (Zustand) so consumers don't need Redux.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./google-drive": {
      "types": "./dist/google-drive/index.d.ts",
      "import": "./dist/google-drive/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "@stoachain/kadena-stoic-legacy": ">=4.3.0",
    "@stoachain/stoa-core": ">=4.3.0",
    "@stoachain/ouronet-core": ">=4.3.0"
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StoaChain/stoa-js.git",
    "directory": "packages/ouronet-codex"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "UNLICENSED"
}
