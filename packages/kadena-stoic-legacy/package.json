{
  "name": "@stoachain/kadena-stoic-legacy",
  "version": "4.1.0",
  "description": "Vendored source of @kadena/{client,cryptography-utils,types,hd-wallet} under StoaChain stewardship. Sovereign supply-chain replacement for the upstream @kadena/* npm packages, preserved byte-identical at v1.18.3 / 0.4.4 / 0.7.0 / 0.6.2.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./cryptography-utils": {
      "types": "./dist/cryptography-utils/index.d.ts",
      "import": "./dist/cryptography-utils/index.js",
      "require": "./dist/cryptography-utils/index.js"
    },
    "./hd-wallet": {
      "types": "./dist/hd-wallet/index.d.ts",
      "import": "./dist/hd-wallet/index.js",
      "require": "./dist/hd-wallet/index.js"
    },
    "./hd-wallet/chainweaver": {
      "types": "./dist/hd-wallet/chainweaver/index.d.ts",
      "import": "./dist/hd-wallet/chainweaver/index.js",
      "require": "./dist/hd-wallet/chainweaver/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE-attribution.md",
    "VENDOR-MANIFEST.sha256"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "prebuild": "node scripts/copy-vendor-files.cjs",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StoaChain/stoa-js.git",
    "directory": "packages/kadena-stoic-legacy"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "peerDependencies": {
    "@kadena/chainweb-node-client": "0.9.5",
    "@kadena/pactjs": "0.6.0",
    "@scure/bip39": "1.2.1",
    "blakejs": "^1.2.1",
    "buffer": "6.0.3",
    "buffer-from": "1.1.2",
    "debug": "4.3.4",
    "ed25519-keygen": "0.4.8",
    "tweetnacl": "^1.0.3"
  },
  "license": "BSD-3-Clause"
}
